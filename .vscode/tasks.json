{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compiler avec Raylib (MSYS2)",
            "type": "shell",
            "command": "C:\\msys64\\mingw64\\bin\\gcc.exe",
            "args": [
                "-Wall",
                "-Wextra",
                "-g3",
                "Untitled-1.c",
                "-o",
                "chess.exe",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                "-lm"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Lancer le jeu d'Echecs",
            "type": "shell",
            "command": ".\\chess.exe",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": "Compiler avec Raylib (MSYS2)",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}
